{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile.web",
    "buildCommand": null,
    "watchPatterns": [
      "/Dockerfile.web",
      "/package.json",
      "/package-lock.json",
      "/tsconfig.base.json",
      "/packages/**",
      "/apps/web/**"
    ]
  },
  "deploy": {
    "startCommand": null,
    "healthcheckPath": "/",
    "restartPolicyType": "ON_FAILURE"
  }
}
