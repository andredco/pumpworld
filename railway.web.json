{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "NPM_CONFIG_PRODUCTION=false npm ci && npm run build -w @pumpworld/web",
    "watchPatterns": [
      "/Dockerfile.web",
      "/Dockerfile",
      "/package.json",
      "/package-lock.json",
      "/tsconfig.base.json",
      "/packages/**",
      "/apps/web/**",
      "/railway.web.json"
    ]
  },
  "deploy": {
    "startCommand": "npm run start -w @pumpworld/web",
    "healthcheckPath": "/",
    "healthcheckTimeout": 180,
    "restartPolicyType": "ON_FAILURE"
  }
}
