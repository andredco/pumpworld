{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile.web",
    "buildCommand": null,
    "watchPatterns": [
      "/Dockerfile.web",
      "/Dockerfile",
      "/package.json",
      "/package-lock.json",
      "/tsconfig.base.json",
      "/packages/**",
      "/apps/web/**",
      "/railway.web.json"
    ]
  },
  "deploy": {
    "startCommand": null,
    "healthcheckPath": "/healthz",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_FAILURE"
  }
}
