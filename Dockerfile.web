# Static viewer for Railway — use for the **@pumpworld/web** service only.
# Sim uses ./Dockerfile (see RAILWAY.md).
FROM node:22-bookworm-slim AS build

WORKDIR /app
SHELL ["/bin/bash", "-o", "pipefail", "-c"]
ENV NPM_CONFIG_CACHE=/tmp/npm-cache

COPY package.json package-lock.json tsconfig.base.json ./
COPY packages ./packages
COPY apps/web ./apps/web

RUN echo "=== pumpworld Dockerfile.web ===" \
  && mkdir -p /tmp/npm-cache \
  && npm config set cache /tmp/npm-cache \
  && NODE_ENV=development NPM_CONFIG_PRODUCTION=false \
     npm install --no-audit --no-fund --prefer-online

# Baked into the JS bundle at build time (set in Railway → Variables → Build / Docker ARG).
ARG PUMPWORLD_HTTP_URL=http://127.0.0.1:8787
ARG PUMPWORLD_WS_URL=ws://127.0.0.1:8788
ENV PUMPWORLD_HTTP_URL=$PUMPWORLD_HTTP_URL
ENV PUMPWORLD_WS_URL=$PUMPWORLD_WS_URL

RUN npm run build -w @pumpworld/web \
  && test -f apps/web/dist/index.html \
  || (echo "ERROR: apps/web/dist/index.html missing after build" && ls -la apps/web && exit 1)

FROM node:22-bookworm-slim
RUN npm install -g serve@14.2.4
WORKDIR /srv
COPY --from=build /app/apps/web/dist ./dist
RUN test -f dist/index.html || (echo "ERROR: runtime dist/index.html missing" && ls -la && exit 1)
ENV NODE_ENV=production
CMD ["sh", "-c", "exec serve -s dist --listen tcp://0.0.0.0:${PORT:-3000}"]
