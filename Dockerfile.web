# Static viewer for Railway — use for the **@pumpworld/web** service only.
# Sim uses ./Dockerfile (see RAILWAY.md).
#
# Runtime config: PUMPWORLD_HTTP_URL and PUMPWORLD_WS_URL are read at
# container start (not build time) by serve-production.mjs, which writes
# them into dist/runtime-config.js. The same image works in any deploy.
FROM node:22-bookworm-slim AS build

WORKDIR /app
SHELL ["/bin/bash", "-o", "pipefail", "-c"]
ENV NPM_CONFIG_CACHE=/tmp/npm-cache

COPY package.json package-lock.json tsconfig.base.json ./
COPY docs ./docs
COPY AGENTS.md ./AGENTS.md
COPY packages ./packages
COPY apps/web ./apps/web

RUN echo "=== pumpworld Dockerfile.web ===" \
  && mkdir -p /tmp/npm-cache \
  && npm config set cache /tmp/npm-cache \
  && NODE_ENV=development NPM_CONFIG_PRODUCTION=false \
     npm install --no-audit --no-fund --prefer-online

# Build-time defaults are intentionally empty — runtime config takes over.
# (Setting these as ARGs would pin URLs into the bundle. Don't.)
RUN npm run build -w @pumpworld/web \
  && test -f apps/web/dist/index.html \
  || (echo "ERROR: apps/web/dist/index.html missing after build" && ls -la apps/web && exit 1)

FROM node:22-bookworm-slim
WORKDIR /srv

# Bring the workspace package.json + scripts so serve-production.mjs can
# write runtime-config.js into dist/ at container start. The script only
# needs Node + npm + the dist tree; no native deps.
COPY apps/web/package.json ./apps/web/package.json
COPY apps/web/scripts ./apps/web/scripts
COPY --from=build /app/apps/web/dist ./apps/web/dist
RUN test -f apps/web/dist/index.html || (echo "ERROR: runtime dist/index.html missing" && ls -la apps/web && exit 1)

# Pre-install `serve` globally so the start script doesn't have to npm-install
# anything at boot. Keeps cold start fast.
RUN npm install -g serve@14.2.4

ENV NODE_ENV=production
WORKDIR /srv/apps/web
CMD ["node", "scripts/serve-production.mjs"]
